# General

theme = Homebrew

# Override dark (4) and light (12) blue to be cyan for better readability on dark backgrounds
palette = 4=#00a6b2
palette = 12=#00e5e5

# Unfocused split: do not add overlay
unfocused-split-opacity = 1
# Homebrew dirty yellow
split-divider-color = #999900

font-size = 10
mouse-hide-while-typing = true
confirm-close-surface = false

# Copy on text select to the system clipboard
copy-on-select = clipboard

# Disable Ghostty's shell integration to prevent conflicts with Pure prompt.
# Ghostty's OSC 133 prompt marking inserts escape sequences into PS1 that break
# Pure's prompt reconstruction, causing the path line (~) to duplicate on each
# command. Pure already handles title setting, and oh-my-zsh handles the rest.
shell-integration = none

# Macos specific

macos-titlebar-style = hidden

keybind = super+shift+r=reload_config

# ------ Keybindings ------
# Note: Terminal splitting is handled by tmux

keybind = super+left=goto_split:previous
keybind = super+right=goto_split:next

# Window navigation for tmux (sends text sequences that tmux can bind to)
keybind = ctrl+super+left=text:\x18N
keybind = ctrl+super+right=text:\x18P

# Window reordering for tmux (sends C-x { and C-x })
keybind = ctrl+super+shift+left=text:\x18{
keybind = ctrl+super+shift+right=text:\x18}

keybind = super+shift+,=scroll_to_top
keybind = super+shift+.=scroll_to_bottom
keybind = ctrl+up=scroll_page_fractional:-0.3
keybind = ctrl+down=scroll_page_fractional:0.3
