{
    "$schema": "https://opencode.ai/config.json",
    "plugin": [],
    "provider": {
        "openrouter": {
            "models": {
                "moonshotai/kimi-k2.5": {
                    "options": {
                        "provider": {
                            "order": ["baseten/fp4"],
                            "allow_fallbacks": false
                        }
                    }
                }
            }
        }
    },
    "permission": {
        "bash": {
            "*": "allow",
            "sudo*": "ask",
            "gcloud*": "ask",
            "gcloud logging*": "allow",
            "gsutil*": "ask",
            "ssh*": "ask",
            "git commit*": "ask",
            "rm*": "ask",
            "docker compose*": "deny",
            "docker exec*": "ask",
            "kubectl*": "ask",
            "kubectl get*": "allow",
            "kubectl describe*": "allow",
            "kubectl logs*": "allow",
            "kubectl config view*": "allow",
        },
        "webfetch": "allow"
    }
}
