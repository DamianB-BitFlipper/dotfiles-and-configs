{
  "$schema": "https://opencode.ai/tui.json",
  "keybinds": {
    "sidebar_toggle": "ctrl+b",
    "session_child_cycle": "ctrl+;",
    "session_child_cycle_reverse": "ctrl+l",
    "model_list": "<leader>m",
    "agent_cycle": "ctrl+n",
    "agent_cycle_reverse": "alt+n",
    "model_cycle_favorite": "ctrl+f",
    "model_cycle_favorite_reverse": "none",
    "model_cycle_recent": "tab",
    "model_cycle_recent_reverse": "shift+tab"
  },
  "scroll_speed": 3,
  "scroll_acceleration": {
    "enabled": true
  }
}